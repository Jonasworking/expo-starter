{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | { read file_path; if echo \"$file_path\" | grep -qE '\\.(js|ts|cjs|mjs|d\\.cts|d\\.mts|jsx|tsx|json|jsonc|css)$'; then pnpm exec biome format --write --files-ignore-unknown=true \"$file_path\"; fi; }"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pnpm exec biome check --write --diagnostic-level=error --no-errors-on-unmatched --files-ignore-unknown=true ."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "expo-app-design@expo-plugins": true,
    "upgrading-expo@expo-plugins": true,
    "expo-deployment@expo-plugins": true
  }
}
