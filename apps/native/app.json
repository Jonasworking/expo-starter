{
  "expo": {
    "scheme": "expo-starter",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "expo-starter",
    "slug": "expo-starter",
    "icon": "./assets/images/icon.png",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "plugins": ["expo-font", "expo-notifications"],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
