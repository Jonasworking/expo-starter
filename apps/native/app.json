{
  "expo": {
    "name": "Ronin",
    "slug": "expo-starter",
    "version": "1.0.0",
    "scheme": "expo-starter",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "web": {
      "bundler": "metro"
    },
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.jonasworking.ronin",
      "supportsTablet": false
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E0E0E",
          "image": "./assets/fenrir/wolf_idle.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65043c66-b141-4887-be3d-39a55cdcff38"
      }
    }
  }
}