{
  "expo": {
    "scheme": "expo-starter",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "web": {
      "bundler": "metro"
    },
    "name": "expo-starter",
    "slug": "expo-starter",
    "icon": "./assets/images/icon.png",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-font",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E0E0E",
          "image": "./assets/fenrir/wolf_idle.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
